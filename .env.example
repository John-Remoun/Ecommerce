# Application
APPLICATION_NAME=ecommerce-backend
PORT=8000

# MongoDB
DB_URI=mongodb://localhost:27017/ecommmerce

# Encryption
ENC_KEY=0123456789abcdef0123456789abcdef
ENC_IV_LENGTH=16

# JWT / token secrets
User_TOKEN_SECRET_KEY=replace_with_a_long_random_secret
System_TOKEN_SECRET_KEY=replace_with_a_long_random_secret
User_REFRESH_TOKEN_SECRET_KEY=replace_with_a_long_random_secret
System_REFRESH_TOKEN_SECRET_KEY=replace_with_a_long_random_secret
ACCESS_EXPIRES_IN=1800
REFRESH_EXPIRES_IN=31536000

# Password hashing
SALT_ROUND=10

# OAuth / client IDs
CLIENT_IDS=web-client,admin-client

# Redis
REDIS_URI=redis://localhost:6379

# Email sender
EMAIL_APP=your-email@example.com
EMAIL_APP_PASSWORD=your-app-password

# Social links
FACEBOOK_LINK=https://facebook.com/your-page
INSTAGRAM_LINK=https://instagram.com/your-profile
TWITTER_LINK=https://twitter.com/your-profile

# Allowed frontend origins (comma-separated)
ORIGINS=http://localhost:3000

# S3 / object storage
S3_REGION=us-east-1
S3_EXPIRES_IN=120
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
REQUIRE_EMAIL_VERIFICATION=false
NODE_ENV=development
